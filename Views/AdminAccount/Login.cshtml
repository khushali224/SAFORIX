@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>SAFORIX | Admin Login</title>

    <!-- Admin CSS -->
    <link rel="stylesheet" href="~/css/Admin/admin.css" asp-append-version="true" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
          crossorigin="anonymous" />
</head>

<body>

    <div class="auth-wrapper">

        <!-- Decorative shapes -->
        <div class="background-shape"></div>
        <div class="secondary-shape"></div>

        <!-- ================= ADMIN LOGIN FORM ================= -->
        <div class="credentials-panel signin">
            <h2 class="slide-element">Admin Login</h2>

            <form asp-action="Login" asp-controller="AdminAccount" method="post">

                <div class="field-wrapper slide-element">
                    <input type="text" name="username" required />
                    <label>Admin Username</label>
                    <i class="fa-solid fa-user-shield"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="password" name="password" required />
                    <label>Password</label>
                    <i class="fa-solid fa-lock"></i>
                </div>

                @if (ViewBag.Error != null)
                {
                    <p style="color:red">@ViewBag.Error</p>
                }

                <div class="field-wrapper slide-element">
                    <button class="submit-button" type="submit">Login</button>
                </div>

            </form>
        </div>

        <div class="welcome-section signin">
            <h2 class="slide-element">ADMIN PANEL</h2>
        </div>

    </div>

    <!-- Admin JS -->
    <script src="~/js/Admin/admin.js" asp-append-version="true"></script>

</body>
</html>
