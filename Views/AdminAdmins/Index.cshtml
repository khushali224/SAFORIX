@model IEnumerable<SAFORIX.Models.AdminUser>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Admins";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">

    <div class="page-header">
        <h1>🛡 Manage Admins</h1>
        <a asp-action="Create" class="btn-add">
            <i class="fa-solid fa-plus"></i> Add Admin
        </a>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var admin in Model)
                    {
                        <tr>
                            <td>@admin.Id</td>
                            <td>@admin.Username</td>
                            <td class="actions">
                                <a asp-action="Edit"
                                   asp-route-id="@admin.Id"
                                   class="btn-edit">
                                    <i class="fa-solid fa-pen"></i>
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@admin.Id"
                                   class="btn-delete"
                                   onclick="return confirm('Are you sure you want to delete this admin?')">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="no-data">No admins found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</section>
