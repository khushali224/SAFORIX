@model SAFORIX.Models.HeaderNavItem
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Nav Item";
    var parents = ViewBag.Parents as IEnumerable<SAFORIX.Models.HeaderNavItem> ?? new List<SAFORIX.Models.HeaderNavItem>();
}

<link rel="stylesheet" href="~/css/Admin/admin-form.css" />

<section class="admin-form-page">
    <h2>Edit Header Nav Item</h2>
    <form method="post" asp-action="Edit">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label>Display Text</label>
            <input asp-for="DisplayText" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Controller</label>
            <input asp-for="Controller" class="form-control" />
        </div>
        <div class="form-group">
            <label>Action</label>
            <input asp-for="Action" class="form-control" />
        </div>
        <div class="form-group">
            <label>Parent</label>
            <select asp-for="ParentId" class="form-control">
                <option value="">-- Top Level --</option>
                @foreach (var p in parents)
                {
                    <option value="@p.Id">@p.DisplayText</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Sort Order</label>
            <input asp-for="SortOrder" type="number" class="form-control" />
        </div>
        <div class="form-group">
            <label><input asp-for="IsActive" type="checkbox" /> Active</label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-success">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
