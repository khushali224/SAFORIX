@model IEnumerable<SAFORIX.Models.HeaderNavItem>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Header Navigation";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1>Header Navigation</h1>
        <a asp-action="Create" class="btn-add"><i class="fa-solid fa-plus"></i> Add Nav Item</a>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Display Text</th>
                    <th>Controller</th>
                    <th>Action</th>
                    <th>Parent</th>
                    <th>Sort</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var parent = item.ParentId.HasValue ? (Model?.FirstOrDefault(x => x.Id == item.ParentId)?.DisplayText ?? "N/A") : "-";
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.DisplayText</td>
                            <td>@(item.Controller ?? "-")</td>
                            <td>@(item.Action ?? "-")</td>
                            <td>@parent</td>
                            <td>@item.SortOrder</td>
                            <td class="actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fa-solid fa-pen"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="no-data">No nav items found</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
