@model SAFORIX.Models.HeaderNavItem
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Nav Item";
}

<link rel="stylesheet" href="~/css/Admin/admin-form.css" />

<section class="admin-form-page">
    <h2>Add Header Nav Item</h2>
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Display Text</label>
            <input asp-for="DisplayText" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Controller</label>
            <input asp-for="Controller" class="form-control" placeholder="Home, About, Services" />
        </div>
        <div class="form-group">
            <label>Action</label>
            <input asp-for="Action" class="form-control" placeholder="Index, UrlScan" />
        </div>
        <div class="form-group">
            <label>Parent (leave empty for top level)</label>
            <select asp-for="ParentId" class="form-control">
                <option value="">-- Top Level --</option>
                @if (ViewBag.Parents != null)
                {
                    @foreach (var p in (IEnumerable<SAFORIX.Models.HeaderNavItem>)ViewBag.Parents)
                    {
                        <option value="@p.Id">@p.DisplayText</option>
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>Sort Order</label>
            <input asp-for="SortOrder" type="number" class="form-control" value="0" />
        </div>
        <div class="form-group">
            <label><input asp-for="IsActive" type="checkbox" checked /> Active</label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-success">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
