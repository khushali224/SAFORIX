@model IEnumerable<SAFORIX.Models.UrlScanHistory>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "URL Scan History";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1>URL Scan History</h1>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th class="url">URL</th>
                    <th>Risk %</th>
                    <th>Level</th>
                    <th>Result</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@(item.User?.username ?? "Guest")</td>
                            <td class="url">@item.Url</td>
                            <td>@item.RiskPercentage%</td>
                            <td><span class="badge @(item.RiskLevel?.ToLower().Replace(" ", "-") ?? "safe")">@item.RiskLevel</span></td>
                            <td style="max-width:300px;">@item.AnalysisResult</td>
                            <td>@item.ScannedAt.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="no-data">No URL scan history found</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
