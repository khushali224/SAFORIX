@model SAFORIX.Models.PageContent
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Page Content";
}

<link rel="stylesheet" href="~/css/Admin/admin-form.css" />

<section class="admin-form-page">
    <h2>➕ Add Page Content</h2>

    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Page</label>
            <select asp-for="PageKey" class="form-control" required>
                @foreach (var pk in (string[])ViewBag.PageKeys)
                {
                    <option value="@pk">@pk</option>
                }
            </select>
        </div>
        <div class="form-group">
            <label>Section Key</label>
            <input asp-for="SectionKey" class="form-control" placeholder="e.g. hero, mission, feature1" required />
        </div>
        <div class="form-group">
            <label>Title</label>
            <input asp-for="Title" class="form-control" placeholder="Optional title" />
        </div>
        <div class="form-group">
            <label>Body / Content</label>
            <textarea asp-for="Body" class="form-control" rows="5" placeholder="HTML or text content"></textarea>
        </div>
        <div class="form-group">
            <label>Sort Order</label>
            <input asp-for="SortOrder" type="number" class="form-control" value="0" />
        </div>
        <div class="form-group">
            <label><input asp-for="IsActive" type="checkbox" checked /> Active</label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-success">Create</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
