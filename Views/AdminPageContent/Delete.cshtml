@model SAFORIX.Models.PageContent
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Page Content";
}

<link rel="stylesheet" href="~/css/Admin/admin-form.css" />

<section class="admin-form-page">
    <h2>🗑️ Delete Page Content</h2>
    <p class="delete-box">Are you sure you want to delete this content?<br /><strong>@Model.PageKey / @Model.SectionKey - @(Model.Title ?? "No title")</strong></p>
    <form method="post" asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
