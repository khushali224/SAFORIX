@model IEnumerable<SAFORIX.Models.BehaviourScanHistory>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Behaviour Scan History";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1>Behaviour Scan History</h1>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Login Time</th>
                    <th>Device</th>
                    <th>IP / Location</th>
                    <th>Risk %</th>
                    <th>Level</th>
                    <th>Result</th>
                    <th>Scanned At</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@(item.User?.username ?? "Guest")</td>
                            <td>@item.Email</td>
                            <td>@item.LoginTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                @(item.DeviceName ?? "N/A")
                                <div style="opacity:.75;font-size:12px;">@(item.DeviceType ?? "-") | @(item.OperatingSystem ?? "-") | @(item.Browser ?? "-")</div>
                            </td>
                            <td>
                                @(item.IpAddress ?? "N/A")
                                <div style="opacity:.75;font-size:12px;">@(item.Location ?? "N/A")</div>
                            </td>
                            <td>@item.RiskPercentage%</td>
                            <td><span class="badge @(item.RiskLevel?.ToLower() ?? "safe")">@item.RiskLevel</span></td>
                            <td style="max-width:280px;">@item.AnalysisResult</td>
                            <td>@item.ScannedAt.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="10" class="no-data">No behaviour scan history found</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
