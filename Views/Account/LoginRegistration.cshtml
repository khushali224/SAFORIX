@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>SAFORIX | Login & Register</title>

    <!-- Local CSS -->
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
          crossorigin="anonymous" />
</head>

<body>

    <div class="auth-wrapper">

        <!-- Decorative shapes -->
        <div class="background-shape"></div>
        <div class="secondary-shape"></div>

        <!-- ================= LOGIN FORM ================= -->
        <div class="credentials-panel signin">
            <h2 class="slide-element">Login</h2>

            <form asp-action="Login" asp-controller="Account" method="post">

                <div class="field-wrapper slide-element">
                    <input type="text" name="username" required />
                    <label>Username</label>
                    <i class="fa-solid fa-user"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="password" name="password" required />
                    <label>Password</label>
                    <i class="fa-solid fa-lock"></i>
                </div>

                <!-- CAPTCHA -->
                <div class="field-wrapper slide-element captcha-box">
                    <span class="captcha-text">@ViewBag.Captcha</span>
                    <input type="text" name="captcha" placeholder="Enter Captcha" required />
                </div>

                <div class="field-wrapper slide-element">
                    <button class="submit-button" type="submit">Login</button>
                </div>

                <div class="switch-link slide-element">
                    <p>
                        Don't have an account?<br />
                        <a href="javascript:void(0)" class="register-trigger">Sign Up</a>
                    </p>
                </div>

            </form>
        </div>

        <div class="welcome-section signin">
            <h2 class="slide-element">WELCOME BACK!</h2>
        </div>

        <!-- ================= REGISTER FORM ================= -->
        <div class="credentials-panel signup">
            <h2 class="slide-element">Register</h2>

            <form asp-action="Register" asp-controller="Account" method="post">

                <div class="field-wrapper slide-element">
                    <input type="text" name="username" required />
                    <label>Username</label>
                    <i class="fa-solid fa-user"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="email" name="email" required />
                    <label>Email</label>
                    <i class="fa-solid fa-envelope"></i>
                </div>

                <div class="field-wrapper slide-element">
                    <input type="password" name="password" required />
                    <label>Password</label>
                    <i class="fa-solid fa-lock"></i>
                </div>

                <!-- CAPTCHA -->
                <div class="field-wrapper slide-element captcha-box">
                    <span class="captcha-text">@ViewBag.Captcha</span>
                    <input type="text" name="captcha" placeholder="Enter Captcha" required />
                </div>

                <div class="field-wrapper slide-element">
                    <button class="submit-button" type="submit">Register</button>
                </div>

                <div class="switch-link slide-element">
                    <p>
                        Already have an account?<br />
                        <a href="javascript:void(0)" class="login-trigger">Sign In</a>
                    </p>
                </div>

            </form>
        </div>

        <div class="welcome-section signup">
            <h2 class="slide-element">WELCOME!</h2>
        </div>

    </div>

    <!-- Local JS -->
    <script src="~/js/register.js" asp-append-version="true"></script>

    

</body>
</html>
