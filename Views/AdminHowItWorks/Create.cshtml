@model SAFORIX.Models.HowItWorksStep
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Step";
}
<div class="admin-section">
    <h2><i class="fas fa-plus"></i> Add Step</h2>
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Step Title</label>
            <input asp-for="StepTitle" class="form-control" placeholder="e.g. 📥 Data Input" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Step description..."></textarea>
        </div>
        <div class="form-group">
            <label>Step Order</label>
            <input asp-for="StepOrder" type="number" class="form-control" value="1" />
        </div>
        <div class="form-group form-check">
            <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
            <label class="form-check-label">Active</label>
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
