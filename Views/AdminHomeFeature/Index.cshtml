@model IEnumerable<SAFORIX.Models.HomeFeature>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Home Features";
}
<div class="admin-section">
    <div class="admin-section-header">
        <h2><i class="fas fa-th-large"></i> Home Features</h2>
        <a asp-action="Create" class="btn-add"><i class="fas fa-plus"></i> Add Feature</a>
    </div>
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr><th>#</th><th>Icon</th><th>Title</th><th>Description</th><th>Order</th><th>Active</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" class="no-data">No features found.</td></tr> }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td style="font-size:1.4rem">@item.Icon</td>
                        <td><strong>@item.Title</strong></td>
                        <td>@(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "…" : item.Description)</td>
                        <td>@item.DisplayOrder</td>
                        <td>@(item.IsActive ? "✅" : "❌")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fas fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
