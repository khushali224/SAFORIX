@model SAFORIX.Models.HomeFeature
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Feature";
}
<div class="admin-section">
    <h2><i class="fas fa-plus"></i> Add Home Feature</h2>
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Icon (emoji)</label>
            <input asp-for="Icon" class="form-control" placeholder="e.g. ⚡ 🔒 👁 🛡" />
        </div>
        <div class="form-group">
            <label>Title</label>
            <input asp-for="Title" class="form-control" placeholder="Feature title" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Feature description"></textarea>
        </div>
        <div class="form-group">
            <label>Display Order</label>
            <input asp-for="DisplayOrder" type="number" class="form-control" value="0" />
        </div>
        <div class="form-group form-check">
            <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
            <label class="form-check-label">Active</label>
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
