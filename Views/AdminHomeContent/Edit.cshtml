@model SAFORIX.Models.HomeContent
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Home Content";
}
<div class="admin-section">
    <h2><i class="fas fa-pen"></i> Edit Home Content</h2>
    <form asp-action="Edit" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="form-group">
            <label>Section Key</label>
            <input asp-for="SectionKey" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        <div class="form-group">
            <label>Body</label>
            <textarea asp-for="Body" class="form-control" rows="4"></textarea>
        </div>
        <div class="form-group">
            <label>Sort Order</label>
            <input asp-for="SortOrder" type="number" class="form-control" />
        </div>
        <div class="form-group form-check">
            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
            <label class="form-check-label">Active</label>
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Update</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
