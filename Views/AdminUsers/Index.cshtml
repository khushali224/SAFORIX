@model IEnumerable<SAFORIX.Models.Registration>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Users";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1>Manage Users</h1>
        <a asp-action="Create" class="btn-add"><i class="fa-solid fa-plus"></i> Add User</a>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
    @if (Model != null && Model.Any())
    {
        @foreach (var user in Model)
        {
        <tr>
            <td>@user.Id</td>
            <td>@user.username</td>
            <td>@user.email</td>
            <td class="actions">
                <a asp-action="Edit" asp-route-id="@user.Id" class="btn-edit"><i class="fa-solid fa-pen"></i></a>
                <a asp-action="Delete" asp-route-id="@user.Id" class="btn-delete"><i class="fa-solid fa-trash"></i></a>
            </td>
        </tr>
        }
    }
    else
    {
        <tr><td colspan="4" class="no-data">No users found</td></tr>
    }
            </tbody>
        </table>
    </div>
</section>
