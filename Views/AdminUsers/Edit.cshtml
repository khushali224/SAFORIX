@model SAFORIX.Models.Registration
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit User";
}

<link rel="stylesheet" href="~/css/Admin/admin-form.css" />

<section class="admin-form-page">
    <h2>Edit User</h2>

    <form asp-action="Edit" method="post" asp-controller="AdminUsers">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" class="form-control" value="@Model.username" required />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" value="@Model.email" required />
        </div>

        <div class="form-group">
            <label>New Password (optional)</label>
            <input type="password" name="newPassword" class="form-control" placeholder="Leave blank to keep existing" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-success">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
