<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - SAFORIX Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ADMIN CSS -->
    <link rel="stylesheet" href="~/css/Admin/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

    <div class="admin-wrapper">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar" id="sidebar">

            <div class="sidebar-logo">
                🛡 <span>SAFORIX</span>
                <small>Admin Panel</small>
            </div>

            <ul class="sidebar-menu">

                <li>
                    <a asp-controller="AdminDashboard" asp-action="Index">
                        <i class="fa-solid fa-gauge"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="menu-title">Management</li>

                <li class="has-submenu">
                    <a href="javascript:void(0)">
                        <i class="fa-solid fa-user-shield"></i>
                        <span>Manage Admin</span>
                        <i class="fa-solid fa-chevron-down arrow"></i>
                    </a>
                    <ul class="submenu">
                        <li><a asp-controller="AdminAdmins" asp-action="Index">View Admins</a></li>
                        <li><a asp-controller="AdminAdmins" asp-action="Create">Add Admin</a></li>
                    </ul>
                </li>

                <li>
                    <a asp-controller="AdminUsers" asp-action="Index">
                        <i class="fa-solid fa-users"></i>
                        <span>Manage Users</span>
                    </a>
                </li>

                <li class="menu-title">Scan History</li>

                <li>
                    <a asp-controller="AdminUrlScan" asp-action="Index">
                        <i class="fa-solid fa-link"></i>
                        <span>URL Scan History</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminDeviceScan" asp-action="Index">
                        <i class="fa-solid fa-desktop"></i>
                        <span>Device Scan History</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminBehaviourScan" asp-action="Index">
                        <i class="fa-solid fa-brain"></i>
                        <span>Behaviour Scan History</span>
                    </a>
                </li>

                <li class="menu-title">Page Content</li>

                <li>
                    <a asp-controller="AdminHomeContent" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span>Home</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminAboutUsContent" asp-action="Index">
                        <i class="fa-solid fa-address-card"></i>
                        <span>About Us</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminThreatContent" asp-action="Index">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Threat</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="AdminHeaderNav" asp-action="Index">
                        <i class="fa-solid fa-bars"></i>
                        <span>Navigation</span>
                    </a>
                </li>

                

                <li class="logout">
                    <a asp-controller="AdminAccount" asp-action="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </a>
                </li>

            </ul>
        </aside>

        <!-- MAIN -->
        <main class="admin-content" id="mainContent">

            <div class="topbar">
                <button id="toggleSidebar">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            @RenderBody()
        </main>

    </div>

    <script src="~/js/Admin/sidebar.js" asp-append-version="true"></script>
</body>
</html>
