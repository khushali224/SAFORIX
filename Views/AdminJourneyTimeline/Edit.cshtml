@model SAFORIX.Models.JourneyTimeline
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Timeline Entry";
}
<div class="admin-section">
    <h2><i class="fas fa-pen"></i> Edit Timeline Entry</h2>
    <form asp-action="Edit" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label>Year</label>
            <input asp-for="Year" type="number" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="form-group">
            <label>Display Order</label>
            <input asp-for="DisplayOrder" type="number" class="form-control" />
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Update</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
