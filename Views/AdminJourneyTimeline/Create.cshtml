@model SAFORIX.Models.JourneyTimeline
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Timeline Entry";
}
<div class="admin-section">
    <h2><i class="fas fa-plus"></i> Add Timeline Entry</h2>
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Year</label>
            <input asp-for="Year" type="number" class="form-control" placeholder="e.g. 2024" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="What happened this year..."></textarea>
        </div>
        <div class="form-group">
            <label>Display Order</label>
            <input asp-for="DisplayOrder" type="number" class="form-control" value="1" />
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
