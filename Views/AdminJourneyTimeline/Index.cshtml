@model IEnumerable<SAFORIX.Models.JourneyTimeline>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Journey Timeline";
}
<div class="admin-section">
    <div class="admin-section-header">
        <h2><i class="fas fa-road"></i> Journey Timeline</h2>
        <a asp-action="Create" class="btn-add"><i class="fas fa-plus"></i> Add Entry</a>
    </div>
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr><th>#</th><th>Year</th><th>Description</th><th>Display Order</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="5" class="no-data">No timeline entries found.</td></tr> }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><strong>@item.Year</strong></td>
                        <td>@(item.Description?.Length > 80 ? item.Description.Substring(0, 80) + "…" : item.Description)</td>
                        <td>@item.DisplayOrder</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fas fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
