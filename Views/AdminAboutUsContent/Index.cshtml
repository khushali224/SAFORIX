@model IEnumerable<SAFORIX.Models.AboutUsContent>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage About Us Content";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1><i class="fa-solid fa-address-card"></i> About Us Content</h1>
        <a asp-action="Create" class="btn-add"><i class="fa-solid fa-plus"></i> Add Content</a>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Body</th>
                    <th>Sort</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="no-data">No content found.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Title</td>
                        <td>@(item.Body?.Length > 60 ? item.Body.Substring(0, 60) + "…" : item.Body)</td>
                        <td>@item.SortOrder</td>
                        <td>@(item.IsActive ? "✅" : "❌")</td>
                        <td class="actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fa-solid fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fa-solid fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
