@model IEnumerable<SAFORIX.Models.DeviceScanHistory>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Device Scan History";
}

<link rel="stylesheet" href="~/css/Admin/admin-table.css" asp-append-version="true" />

<section class="admin-page">
    <div class="page-header">
        <h1>Device Scan History</h1>
    </div>

    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Device</th>
                    <th>OS</th>
                    <th>IP</th>
                    <th>Risk %</th>
                    <th>Level</th>
                    <th>Result</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@(item.User?.username ?? "Guest")</td>
                            <td>
                                @item.DeviceName
                                <div style="opacity:.75;font-size:12px;">@(item.DeviceType ?? "-")</div>
                            </td>
                            <td>@(item.OperatingSystem ?? "N/A")</td>
                            <td>@(item.IpAddress ?? "N/A")</td>
                            <td>@item.RiskPercentage%</td>
                            <td><span class="badge @(item.RiskLevel?.ToLower() ?? "safe")">@item.RiskLevel</span></td>
                            <td class="url" style="max-width:350px;">@item.AnalysisResult</td>
                            <td>@item.ScannedAt.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="no-data">No device scan history found</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>
