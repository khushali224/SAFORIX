@model IEnumerable<SAFORIX.Models.AboutPageContent>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "About Page Content";
}
<div class="admin-section">
    <div class="admin-section-header">
        <h2><i class="fas fa-info-circle"></i> About Page Content</h2>
        <a asp-action="Create" class="btn-add"><i class="fas fa-plus"></i> Add Content</a>
    </div>
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr><th>#</th><th>Title</th><th>Description</th><th>Active</th><th>Created</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="6" class="no-data">No content found.</td></tr> }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><strong>@item.Title</strong></td>
                        <td>@(item.Description?.Length > 70 ? item.Description.Substring(0, 70) + "…" : item.Description)</td>
                        <td>@(item.IsActive ? "✅" : "❌")</td>
                        <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fas fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
