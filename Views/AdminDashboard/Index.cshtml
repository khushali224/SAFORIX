@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<link rel="stylesheet" href="~/css/Admin/dashboard.css" asp-append-version="true" />

<section class="dashboard">

    <!-- ===== DASHBOARD HEADER ===== -->
    <div class="dashboard-header">
        <h1>🛡 SAFORIX Security Dashboard</h1>
        <p>Real-time system overview &amp; threat intelligence</p>
    </div>

    <!-- ===== STATISTICS CARDS ===== -->
    <div class="stat-grid">

        <div class="stat-card glow-blue">
            <h3>Total Users</h3>
            <span class="stat-number">@ViewBag.TotalUsers</span>
            <i class="fa-solid fa-users"></i>
        </div>

        <div class="stat-card glow-purple">
            <h3>Total Admins</h3>
            <span class="stat-number">@ViewBag.TotalAdmins</span>
            <i class="fa-solid fa-user-shield"></i>
        </div>

        <div class="stat-card glow-green">
            <h3>URL Scans</h3>
            <span class="stat-number">@ViewBag.UrlScans</span>
            <i class="fa-solid fa-link"></i>
        </div>

        <div class="stat-card glow-red">
            <h3>Threats Detected</h3>
            <span class="stat-number">@ViewBag.Threats</span>
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>

    </div>

    <!-- ===== PANELS ===== -->
    <div class="panel-grid">

        <!-- Latest Users -->
        <div class="panel">
            <h2>👥 Latest Users</h2>
            <ul>
                @if (ViewBag.LatestUsers != null && ViewBag.LatestUsers.Count > 0)
                {
                    foreach (var user in ViewBag.LatestUsers)
                    {
                        <li>
                            @user.username
                            <span>@user.email</span>
                        </li>
                    }
                }
                else
                {
                    <li>No users found</li>
                }
            </ul>
        </div>

        <!-- Latest Admins -->
        <div class="panel">
            <h2>🛡 Latest Admins</h2>
            <ul>
                @if (ViewBag.LatestAdmins != null && ViewBag.LatestAdmins.Count > 0)
                {
                    foreach (var admin in ViewBag.LatestAdmins)
                    {
                        <li>@admin.Username</li>
                    }
                }
                else
                {
                    <li>No admins found</li>
                }
            </ul>
        </div>

        <!-- System Status -->
        <div class="panel system-panel">
            <h2>⚙ System Status</h2>
            <div class="status">
                <span class="dot green"></span> URL Scanner Online<br />
                <span class="dot green"></span> Device Scanner Online<br />
                <span class="dot green"></span> Behaviour Monitor Active
            </div>
        </div>

    </div>

</section>

<script src="~/js/Admin/dashboard.js" asp-append-version="true"></script>
