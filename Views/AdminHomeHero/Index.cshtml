@model IEnumerable<SAFORIX.Models.HomeHero>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Home Hero Content";
}
<div class="admin-section">
    <div class="admin-section-header">
        <h2><i class="fas fa-star"></i> Home Hero Section</h2>
        <a asp-action="Create" class="btn-add"><i class="fas fa-plus"></i> Add Hero</a>
    </div>
    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th><th>Main Title</th><th>Sub Title</th><th>Description</th><th>Button</th><th>Active</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" class="no-data">No hero content found.</td></tr> }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><strong>@item.MainTitle</strong></td>
                        <td>@item.SubTitle</td>
                        <td>@(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "…" : item.Description)</td>
                        <td><code>@item.ButtonText</code></td>
                        <td>@(item.IsActive ? "✅" : "❌")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fas fa-pen"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
