@model SAFORIX.Models.HomeHero
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Hero";
}
<div class="admin-section">
    <h2><i class="fas fa-pen"></i> Edit Home Hero</h2>
    <form asp-action="Edit" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label>Main Title</label>
            <input asp-for="MainTitle" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Sub Title</label>
            <input asp-for="SubTitle" class="form-control" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="form-group">
            <label>Button Text</label>
            <input asp-for="ButtonText" class="form-control" />
        </div>
        <div class="form-group">
            <label>Button Link</label>
            <input asp-for="ButtonLink" class="form-control" />
        </div>
        <div class="form-group form-check">
            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
            <label class="form-check-label">Active</label>
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Update</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
