@model SAFORIX.Models.HomeHero
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Hero";
}
<div class="admin-section">
    <h2><i class="fas fa-trash"></i> Delete Hero</h2>
    <p>Are you sure you want to delete: <strong>@Model.MainTitle</strong>?</p>
    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn-delete-confirm">Yes, Delete</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
