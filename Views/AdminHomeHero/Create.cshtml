@model SAFORIX.Models.HomeHero
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Hero";
}
<div class="admin-section">
    <h2><i class="fas fa-plus"></i> Add Home Hero</h2>
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Main Title</label>
            <input asp-for="MainTitle" class="form-control" placeholder="e.g. SAFORIX" required />
        </div>
        <div class="form-group">
            <label>Sub Title</label>
            <input asp-for="SubTitle" class="form-control" placeholder="e.g. Security Analysis Framework" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Hero description text"></textarea>
        </div>
        <div class="form-group">
            <label>Button Text</label>
            <input asp-for="ButtonText" class="form-control" placeholder="e.g. Get Started →" />
        </div>
        <div class="form-group">
            <label>Button Link</label>
            <input asp-for="ButtonLink" class="form-control" placeholder="e.g. /Services/UrlScan" />
        </div>
        <div class="form-group form-check">
            <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
            <label class="form-check-label">Active</label>
        </div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
