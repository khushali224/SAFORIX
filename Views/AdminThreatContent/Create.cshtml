@model SAFORIX.Models.ThreatContent
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Add Threat Content"; }
<div class="admin-section">
    <h2><i class="fas fa-plus"></i> Add Threat Content</h2>
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div class="form-group"><label>Section Key</label><input asp-for="SectionKey" class="form-control" placeholder="e.g. threat_1_title, protection_1, tip_1" required /></div>
        <div class="form-group"><label>Title</label><input asp-for="Title" class="form-control" /></div>
        <div class="form-group"><label>Body</label><textarea asp-for="Body" class="form-control" rows="4"></textarea></div>
        <div class="form-group"><label>Sort Order</label><input asp-for="SortOrder" type="number" class="form-control" value="0" /></div>
        <div class="form-group form-check"><input asp-for="IsActive" type="checkbox" class="form-check-input" checked /><label class="form-check-label">Active</label></div>
        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save</button>
        <a asp-action="Index" class="btn-cancel">Cancel</a>
    </form>
</div>
